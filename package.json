{
	"name": "@ymys/directus-extension-sso",
	"description": "Mobile OAuth proxy endpoints for Directus + Keycloak + Google + Apple",
	"icon": "smartphone",
	"version": "2.7.37",
	"keywords": [
		"directus",
		"directus-extension",
		"directus-extension-bundle",
		"sso",
		"keycloak",
		"google",
		"oauth",
		"mobile",
		"auth",
		"proxy"
	],
	"author": "Yusuf M <ymys@users.noreply.github.com>",
	"license": "MIT",
	"homepage": "https://github.com/ymys/directus-sso#readme",
	"bugs": {
		"url": "https://github.com/ymys/directus-sso/issues"
	},
	"publishConfig": {
		"access": "public"
	},
	"type": "module",
	"files": [
		"dist",
		"package.json",
		"README.md",
		"LICENSE"
	],
	"directus:extension": {
		"type": "bundle",
		"host": "^11.0.0",
		"path": {
			"app": "dist/app.js",
			"api": "dist/api.js"
		},
		"entries": [
			{
				"type": "endpoint",
				"name": "sso",
				"source": "src/endpoint.js"
			},
			{
				"type": "hook",
				"name": "sso-hook",
				"source": "src/hook.js"
			}
		]
	},
	"scripts": {
		"build": "directus-extension build",
		"dev": "directus-extension build -w --no-minify",
		"link": "directus-extension link"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/ymys/directus-sso.git"
	},
	"dependencies": {
		"jsonwebtoken": "^9.0.3"
	},
	"devDependencies": {
		"@directus/extensions-sdk": "^17.1.4"
	}
}